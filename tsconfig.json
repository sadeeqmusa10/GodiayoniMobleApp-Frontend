{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,

    "jsx": "react-jsx",
    "jsxImportSource": "nativewind",

    "module": "esnext",
    "moduleResolution": "bundler",

    "types": ["react-native", "node"],
    "lib": ["dom", "esnext"],

    "paths": {
      "@/*": ["./src/*"]
    },

    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "app.config.js"
  ]
}
